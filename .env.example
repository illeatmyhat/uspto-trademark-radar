# Copy to .env (git-ignored; never commit real values).
# The CLI loads this automatically at startup.

# USPTO Open Data Portal key — personal, ID.me-tied (RUNBOOK section 1).
USPTO_API_KEY=

# Hugging Face write token — only needed for `trademark-radar publish`.
HF_TOKEN=

# Optional: put the (large) data tree on another volume.
# Defaults to <repo>/data when unset.
#TRADEMARK_RADAR_DATA_ROOT=D:\uspto-data
